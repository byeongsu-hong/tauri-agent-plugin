{
  "name": "@byeongsu-hong/tauri-plugin-agent",
  "version": "0.1.0",
  "description": "Agent-facing control surface for live Tauri apps using compact semantic trees.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byeongsu-hong/tauri-agent-plugin.git"
  },
  "main": "./dist-js/index.cjs",
  "module": "./dist-js/index.js",
  "types": "./dist-js/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-js/index.d.ts",
      "import": "./dist-js/index.js",
      "require": "./dist-js/index.cjs"
    },
    "./daemon": {
      "types": "./dist-js/daemon.d.ts",
      "import": "./dist-js/daemon.js",
      "require": "./dist-js/daemon.cjs"
    },
    "./protocol": {
      "types": "./dist-js/protocol.d.ts",
      "import": "./dist-js/protocol.js",
      "require": "./dist-js/protocol.cjs"
    }
  },
  "bin": {
    "tauri-agent": "./dist-cli/tauri-agent.js"
  },
  "files": [
    "dist-js",
    "dist-cli",
    "permissions",
    "src",
    "Cargo.toml",
    "build.rs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "commander": "^14.0.0",
    "jsdom": "^26.1.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
