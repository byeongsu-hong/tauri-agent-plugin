{
  "name": "@byeongsu-hong/tauri-agent-plugin",
  "version": "0.0.2",
  "description": "Agent-facing control surface for live Tauri apps using compact semantic trees.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "license": "MIT OR Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "tauri",
    "agent",
    "debugger",
    "automation",
    "mcp",
    "webview",
    "accessibility",
    "semantic-tree"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byeongsu-hong/tauri-agent-plugin.git"
  },
  "main": "./dist-js/index.cjs",
  "module": "./dist-js/index.js",
  "types": "./dist-js/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-js/index.d.ts",
      "import": "./dist-js/index.js",
      "require": "./dist-js/index.cjs"
    },
    "./daemon": {
      "types": "./dist-js/daemon.d.ts",
      "import": "./dist-js/daemon.js",
      "require": "./dist-js/daemon.cjs"
    },
    "./protocol": {
      "types": "./dist-js/protocol.d.ts",
      "import": "./dist-js/protocol.js",
      "require": "./dist-js/protocol.cjs"
    },
    "./mcp": {
      "types": "./dist-js/mcp.d.ts",
      "import": "./dist-js/mcp.js",
      "require": "./dist-js/mcp.cjs"
    }
  },
  "bin": {
    "tauri-agent": "./dist-cli/tauri-agent.js",
    "tauri-agent-mcp": "./dist-cli/tauri-agent-mcp.js"
  },
  "files": [
    "dist-js",
    "dist-cli",
    "permissions",
    "src",
    "Cargo.toml",
    "build.rs",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run test && bun run build",
    "check:rust": "cargo fmt --all -- --check && cargo clippy --all-targets -- -D warnings && cargo test",
    "prepublishOnly": "bun run check"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "commander": "^14.0.0"
  },
  "peerDependencies": {
    "jsdom": "^26.1.0"
  },
  "peerDependenciesMeta": {
    "jsdom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.0",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
