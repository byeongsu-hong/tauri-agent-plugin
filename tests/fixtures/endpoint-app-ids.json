{
  "comment": "Golden cases for endpoint app-id sanitization. Asserted by BOTH tests/endpoint.test.ts (daemon/endpoint.ts safeAppId) and tests/rust_endpoint.rs (src/endpoint.rs safe_app_id) so the dual implementations cannot drift. `safeAppId` is the trailing path component of the runtime dir.",
  "cases": [
    { "appId": "dev.byeongsu.fixture", "safeAppId": "dev.byeongsu.fixture" },
    { "appId": "a-b_c.d", "safeAppId": "a-b_c.d" },
    { "appId": "com.example/../secret", "safeAppId": "com.example~2F..~2Fsecret" },
    { "appId": "a b!c", "safeAppId": "a~20b~21c" },
    { "appId": "Weird™Name", "safeAppId": "Weird~E2~84~A2Name" },
    { "appId": "a/b", "safeAppId": "a~2Fb" },
    { "appId": "a_b", "safeAppId": "a_b" },
    { "appId": "~", "safeAppId": "~7E" },
    { "appId": "\u0000", "safeAppId": "~00" },
    { "appId": "", "safeAppId": "~" },
    { "appId": ".", "safeAppId": "~2E" },
    { "appId": "..", "safeAppId": "~2E~2E" },
    { "appId": "...", "safeAppId": "~2E~2E~2E" }
  ]
