{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tauri Agent Fixture",
  "version": "0.1.0",
  "identifier": "dev.byeongsu.tauri-agent.fixture",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tauri Agent Fixture",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "agent": {
      "inlineServer": {
        "enabled": true,
        "host": "127.0.0.1",
        "port": 0,
        "publishEndpoint": true
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
